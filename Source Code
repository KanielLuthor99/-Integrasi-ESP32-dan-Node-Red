#include <WiFi.h>
#include <PubSubClient.h>
#include "DHT.h"

// --- Konfigurasi WiFi dan MQTT ---
const char* ssid = "NAMA_WIFI_MU";
const char* password = "PASSWORD_WIFI_MU";
const char* mqtt_server = "broker.emqx.io";

// --- Ganti dengan NIM Anda ---
const char* NIM = "22506070xxxxxxx"; 

// --- Definisi Pin ---
#define DHTPIN 4
#define DHTTYPE DHT11
#define LED_PIN 2      // LED Built-in ESP32 atau LED Eksternal
#define BUZZER_PIN 5   // Pin Buzzer

// --- Inisialisasi Sensor dan Jaringan ---
DHT dht(DHTPIN, DHTTYPE);
WiFiClient espClient;
PubSubClient client(espClient);

unsigned long lastMsg = 0;
unsigned long buzzerTurnOffTime = 0;
bool buzzerActive = false;

// String Topik MQTT (Dibuat dinamis berdasarkan NIM)
String topicLed, topicBuzzer, topicSuhu, topicKelembapan;

void setup_wifi() {
  delay(10);
  Serial.println();
  Serial.print("Connecting to ");
  Serial.println(ssid);

  WiFi.begin(ssid, password);

  while (WiFi.status() != WL_CONNECTED) {
    delay(500);
    Serial.print(".");
  }

  Serial.println("");
  Serial.println("WiFi connected");
  Serial.print("IP address: ");
  Serial.println(WiFi.localIP());
}

void callback(char* topic, byte* payload, unsigned int length) {
  Serial.print("Message arrived [");
  Serial.print(topic);
  Serial.print("] ");
  
  String messageTemp;
  for (int i = 0; i < length; i++) {
    messageTemp += (char)payload[i];
  }
  Serial.println(messageTemp);

  // Logika Kontrol LED
  if (String(topic) == topicLed) {
    if (messageTemp == "1") {
      digitalWrite(LED_PIN, HIGH);
      Serial.println("LED ON");
    } else if (messageTemp == "0") {
      digitalWrite(LED_PIN, LOW);
      Serial.println("LED OFF");
    }
  }
  
  // Logika Kontrol Buzzer (Non-blocking menggunakan millis)
  if (String(topic) == topicBuzzer) {
    if (messageTemp == "1") {
      digitalWrite(BUZZER_PIN, HIGH);
      buzzerTurnOffTime = millis() + 3000; // Set waktu mati 3 detik ke depan
      buzzerActive = true;
      Serial.println("Buzzer ON for 3 seconds");
    }
  }
}

void reconnect() {
  while (!client.connected()) {
    Serial.print("Attempting MQTT connection...");
    // Buat client ID unik berdasarkan NIM
    String clientId = "ESP32Client-" + String(NIM);
    if (client.connect(clientId.c_str())) {
      Serial.println("connected");
      
      // Subscribe ke topik setelah berhasil terhubung
      client.subscribe(topicLed.c_str());
      client.subscribe(topicBuzzer.c_str());
      
      Serial.print("Subscribed to: ");
      Serial.concat(topicLed, " and ");
      Serial.println(topicBuzzer);
    } else {
      Serial.print("failed, rc=");
      Serial.print(client.state());
      Serial.println(" try again in 5 seconds");
      delay(5000);
    }
  }
}

void setup() {
  Serial.begin(115200);
  pinMode(LED_PIN, OUTPUT);
  pinMode(BUZZER_PIN, OUTPUT);
  
  digitalWrite(LED_PIN, LOW);
  digitalWrite(BUZZER_PIN, LOW);

  // Inisialisasi nama topik secara dinamis
  topicLed = String(NIM) + "/LED";
  topicBuzzer = String(NIM) + "/BUZZER";
  topicSuhu = String(NIM) + "/SUHU";
  topicKelembapan = String(NIM) + "/KELEMBAPAN";

  dht.begin();
  setup_wifi();
  client.setServer(mqtt_server, 1883);
  client.setCallback(callback);
}

void loop() {
  if (!client.connected()) {
    reconnect();
  }
  client.loop();

  unsigned long now = millis();

  // Pengendalian Buzzer non-blocking (agar pembacaan sensor tidak terganggu delay)
  if (buzzerActive && now >= buzzerTurnOffTime) {
    digitalWrite(BUZZER_PIN, LOW);
    buzzerActive = false;
    Serial.println("Buzzer OFF");
  }

  // Publish data sensor setiap 5 detik (5000 ms)
  if (now - lastMsg > 5000) {
    lastMsg = now;

    float h = dht.readHumidity();
    float t = dht.readTemperature();

    if (isnan(h) || isnan(t)) {
      Serial.println("Failed to read from DHT sensor!");
      return;
    }

    // Publish Suhu
    String tempStr = String(t, 2);
    client.publish(topicSuhu.c_str(), tempStr.c_str());
    Serial.print("Published Temperature: ");
    Serial.println(tempStr);

    // Publish Kelembapan
    String humStr = String(h, 2);
    client.publish(topicKelembapan.c_str(), humStr.c_str());
    Serial.print("Published Humidity: ");
    Serial.println(humStr);
  }
}
